PORT=5000
MONGODB_URI=mongodb://localhost:27017/siteledger
# For Vercel production, set MONGODB_URI in the Vercel dashboard to your MongoDB Atlas URI, e.g.:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/siteledger?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=30d
NODE_ENV=development
UPLOAD_PATH=uploads
MAX_FILE_SIZE=5242880
