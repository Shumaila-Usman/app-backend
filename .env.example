PORT=5000
MONGO_URI=mongodb://localhost:27017/siteledger
# Legacy name also supported: MONGODB_URI
# Production (MongoDB Atlas example):
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/siteledger?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=30d
NODE_ENV=development
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
